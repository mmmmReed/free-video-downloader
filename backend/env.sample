# 后端环境变量（复制为 backend/.env）
#
# Stripe：须在 Dashboard 创建「一次性付款」Price（CNY ¥9.90），不要用按月订阅 Price。
# https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_ID=price_xxxx_one_time_cny

# 前端根 URL（支付完成跳转）
FRONTEND_PUBLIC_URL=http://localhost:3000

# 登录 JWT（须足够随机）
JWT_SECRET=change_me_long_random_string

# 跨域：不设则默认允许本地前端（localhost / 127.0.0.1 的 3000、4173）。
# 局域网 IP 访问前端时必填，逗号分隔，例如：
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.5:3000
# 设为 * 表示任意来源（此时不使用 credentials）
# CORS_ORIGINS=*

# 单次购买 VIP 有效天数（默认 30）
VIP_DURATION_DAYS=30

# （可选）浏览器导出 Netscape 格式的 cookies.txt 绝对路径，供 yt-dlp 拉抖音等平台网页字幕时使用。
# YTDLP_COOKIES_FILE=C:\path\to\cookies.txt
